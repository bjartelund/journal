{plugins, [rebar3_hex]}.
%% rebar.config - add Nitrogen dependency
{erl_opts, [debug_info]}.
%% Nitrogen framework is composed of component libs published on Hex.
%% Using the same versions reflected in existing rebar.lock (can later bump).
{deps, [
    {nitrogen_core, "3.0.0-alpha.13"},
    {simple_bridge,  "2.3.1"},
    {nprocreg,       "0.3.0"},
    {qdate,          "0.7.3"},
    {qdate_localtime,"1.2.1"},
    {nitro_cache,    "0.5.0"},
    {canister,       "0.1.1"},
    {rekt,           "0.1.0"},
    {nitro_qrcode,   "1.1.0"},
    {sync,           "0.4.1"},
    {cowboy,         "2.10.0"}
]}.

%% Ensure apps are compiled in correct order
{applications, [kernel, stdlib]}.

%% relx release configuration so that 'rebar3 release' (used by make daemon) works.
{relx, [
    {release, {journal, "0.1.0"}, [
        kernel,
        stdlib,
        sasl,
        crypto,
        inets,
        ssl,
        public_key,
        runtime_tools,
        cowboy,
        nitrogen_core,
        simple_bridge,
        sync
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true}
]}.
